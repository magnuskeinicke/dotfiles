# Tmux aliases
alias tm='tmux new-session -A -s main'
alias ta='tmux attach'
alias tas='tmux attach -t'
alias tn='tmux new -d -s'
alias tls='tmux ls'
alias tka='tmux kill-session -a'
alias tks='tmux kill-session -t'

# nvim aliases
alias vim='nvim'
alias vsvim='NVIM_APPNAME=nvim-vscode nvim'
alias minivim='NVIM_APPNAME=nvim-mini nvim'

# seranote
alias sn='cd $HOME/Documents/Work/voice-to-text/; source ./tools/scripts/environment/load-variables.sh'
alias sndev='sn; npx nx dev seranote-web --webpack'
alias sntest='sn; npx nx affected -t lint test build e2e'
alias snsb='sn; npx nx storybook storybook-web'

# seranote (current worktree)
vtt-copy-envs() {
  "$HOME/dotfiles/scripts/copy-vtt-envs-to-cwd.sh" "$@"
}
alias snwenv='vtt-copy-envs'
alias snw='source ./tools/scripts/environment/load-variables.sh'
alias snwdev='snw; npx nx dev seranote-web --webpack'
alias snwtest='snw; npx nx affected -t lint test build e2e'
alias snwsb='snw; npx nx storybook storybook-web'

# lazygit
alias lg="lazygit"

# Nimbalyst
alias nimbalyst="$HOME/Applications/squashfs-root/AppRun"
